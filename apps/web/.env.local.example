# 复制此文件为 .env.local 并填入你的密钥
# .env.local 已被 .gitignore 忽略，不会提交到仓库
#
# 支持三个 LLM 提供商（都是 OpenAI 兼容格式），任选其一：
# 不设 LLM_PROVIDER 时自动检测哪个 API Key 已配置

# ── 方案1: DeepSeek（推荐，性价比最高）──
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ── 方案2: 小米 MiMo ──
# 获取地址: 小米大模型开放平台
MIMO_API_KEY=sk-your-mimo-key

# ── 方案3: 阿里云 DashScope ──
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# 可选: 显式指定提供商（不设则自动检测）
# LLM_PROVIDER=deepseek

# ── LLM API Keys (server-side only, never shipped to client) ──
# 支持三个提供商，任选其一。不设 LLM_PROVIDER 时自动检测。

# DeepSeek (推荐，性价比最高)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 小米 MiMo
# 获取地址: 小米大模型开放平台
MIMO_API_KEY=

# 阿里云 DashScope (qwen-max)
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# 可选: 显式指定提供商 (deepseek / mimo / dashscope)
# LLM_PROVIDER=deepseek

# ── Other Keys ──
# Replicate API Token for FLUX image generation (build-time only)
REPLICATE_API_TOKEN=
